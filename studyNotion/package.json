{
  "scripts": {
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "format": "prettier --write .",
    "dev": "concurrently -n BACKEND,FRONTEND -c green,blue \"npm run server\" \"npm run client\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "prettier": "^3.8.1"
  }
}
